{
  "sft": {
    "base_model": "Qwen/Qwen2.5-32B-Instruct",
    "output_dir": "checkpoints/sft",
    "dataset_path": "data/trajectories/sft",
    "num_epochs": 3,
    "per_device_batch_size": 1,
    "gradient_accumulation_steps": 16,
    "learning_rate": 2e-5,
    "weight_decay": 0.01,
    "warmup_ratio": 0.03,
    "lr_scheduler_type": "cosine",
    "max_seq_length": 8192,
    "bf16": true,
    "gradient_checkpointing": true,
    "lora": {
      "r": 64,
      "lora_alpha": 128,
      "lora_dropout": 0.05,
      "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
      "task_type": "CAUSAL_LM"
    },
    "logging_steps": 10,
    "save_steps": 200,
    "eval_steps": 200,
    "save_total_limit": 3,
    "seed": 42,
    "dry_run": false
  },
  "rl": {
    "base_model": "Qwen/Qwen2.5-32B-Instruct",
    "output_dir": "checkpoints/rl",
    "trajectory_path": "data/trajectories/rl",
    "algorithm": "grpo",
    "reward_weights": {
      "answer_correctness": 0.50,
      "kg_quality": 0.20,
      "hypothesis_efficiency": 0.15,
      "falsification_quality": 0.10,
      "format_compliance": 0.05
    },
    "grpo": {
      "num_generations": 4,
      "temperature": 0.7,
      "kl_coeff": 0.1,
      "clip_range": 0.2,
      "reward_baseline": "moving_average",
      "baseline_ema_decay": 0.99
    },
    "num_episodes": 1000,
    "per_device_batch_size": 1,
    "gradient_accumulation_steps": 8,
    "learning_rate": 5e-6,
    "max_seq_length": 8192,
    "max_response_length": 4096,
    "bf16": true,
    "gradient_checkpointing": true,
    "lora": {
      "r": 64,
      "lora_alpha": 128,
      "lora_dropout": 0.05,
      "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
      "task_type": "CAUSAL_LM"
    },
    "seed": 42,
    "dry_run": false
  },
  "eval": {
    "checkpoint_path": "checkpoints/rl/latest",
    "base_model": "Qwen/Qwen2.5-32B-Instruct",
    "eval_dataset": "biomni-eval1",
    "eval_dataset_path": "data/eval/biomni-eval1",
    "output_dir": "eval_results",
    "temperature": 0.1,
    "max_new_tokens": 4096,
    "bf16": true,
    "dry_run": false
  }
}
