# ── LLM ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://yohas:yohas@postgres:5432/yohas

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Yami / ESM ──────────────────────────────────
YAMI_BACKEND=huggingface
HF_API_TOKEN=hf_...
ESM_MODEL=facebook/esm2_t33_650M_UR50D

# ── External APIs (optional — enhance rate limits) ─
NCBI_API_KEY=
S2_API_KEY=

# ── Slack HITL ──────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=yohas-hitl

# ── Research Defaults ───────────────────────────
MAX_HYPOTHESIS_DEPTH=2
MAX_MCTS_ITERATIONS=15
CONFIDENCE_THRESHOLD=0.7
HITL_UNCERTAINTY_THRESHOLD=0.6
HITL_TIMEOUT_SECONDS=600

# ── Container Runtime ──────────────────────────
CONTAINER_RUNTIME=docker
CONTAINER_DEFAULT_IMAGE=yohas-tool-sandbox:latest
CONTAINER_MEMORY_LIMIT=512m
CONTAINER_CPU_LIMIT=1.0
CONTAINER_NETWORK_MODE=none
CONTAINER_TIMEOUT_SECONDS=120

# ── MCP ────────────────────────────────────────
MCP_AUTO_DISCOVER=true

# ── App ─────────────────────────────────────────
API_KEY=dev-api-key-change-me
LOG_LEVEL=INFO
ENVIRONMENT=development
