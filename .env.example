# ── LLM ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://yohas:yohas@postgres:5432/yohas

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Yami / ESM ──────────────────────────────────
YAMI_BACKEND=huggingface
HF_API_TOKEN=hf_...
ESM_MODEL=facebook/esm2_t33_650M_UR50D

# ── External APIs (optional — enhance rate limits) ─
NCBI_API_KEY=
S2_API_KEY=

# ── Slack HITL ──────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=yohas-hitl

# ── Research Defaults ───────────────────────────
MAX_HYPOTHESIS_DEPTH=2
MAX_MCTS_ITERATIONS=15
CONFIDENCE_THRESHOLD=0.7
HITL_UNCERTAINTY_THRESHOLD=0.6
HITL_TIMEOUT_SECONDS=600

# ── App ─────────────────────────────────────────
API_KEY=dev-api-key-change-me
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── MCP ─────────────────────────────────────────
MCP_GATEWAY_PORT=8100
MCP_TOOL_TIMEOUT=30
MCP_MAX_CONCURRENT_TOOLS=10

# ── Benchmark ───────────────────────────────────
BENCHMARK_DB_URL=postgresql+asyncpg://benchmark:benchmark@benchmark-db:5432/yohas_benchmark
BENCHMARK_OUTPUT_DIR=/results

# ── Production (only needed for docker-compose.prod.yml) ─
# PROD_DB_USER=yohas
# PROD_DB_PASSWORD=change-me-in-production
# PROD_DB_NAME=yohas
# PROD_REDIS_PASSWORD=change-me-in-production
# PROD_API_URL=http://api:8000
# PROD_WS_URL=ws://api:8000
